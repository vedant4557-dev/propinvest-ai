# PropInvest AI - Environment Variables

# ========== Backend (FastAPI) ==========
# OpenAI API key for AI analysis. If not set, a mock analysis is returned.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Custom API base URL (for Azure, local models, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ========== Frontend (Next.js) ==========
# Create frontend/.env.local with:
# NEXT_PUBLIC_API_URL=http://localhost:8000
